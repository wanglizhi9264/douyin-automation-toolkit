{
  "manifest_version": 3,
  "name": "抖音收藏备份助手",
  "version": "0.2.1",
  "description": "本地管理抖音喜欢列表收藏、审计和视频备份。",
  "action": {
    "default_title": "抖音收藏备份助手"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": [
    "storage",
    "tabs",
    "downloads",
    "downloads.ui"
  ],
  "host_permissions": [
    "https://www.douyin.com/*",
    "https://*.douyin.com/*",
    "https://*.douyinpic.com/*",
    "https://*.douyinvod.com/*",
    "https://*.douyinstatic.com/*",
    "https://*.byteimg.com/*",
    "https://*.bytecdntp.com/*",
    "https://*.bytedance.com/*",
    "https://*.snssdk.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.douyin.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "https://www.douyin.com/*"
      ],
      "resources": [
        "src/injected.js",
        "src/content.css",
        "src/sidebar/index.html",
        "src/sidebar/app.js",
        "src/sidebar/style.css",
        "src/folder-picker/index.html",
        "src/folder-picker/app.js",
        "src/shared/db.js",
        "src/shared/state.js",
        "src/shared/api.js",
        "src/shared/download.js",
        "src/shared/download-record.js",
        "src/shared/events.js"
      ]
    }
  ]
}
